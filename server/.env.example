# Copy this file to .env and fill in your real API key.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional — port the server listens on (defaults to 3001).
# Named SERVER_PORT (not PORT) on purpose: some tools/IDEs set a machine-level
# PORT variable, and since dotenv never overrides an already-set env var, a
# plain PORT here could get silently ignored. SERVER_PORT avoids that collision.
SERVER_PORT=3001

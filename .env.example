# Frontend (Vite) — exposed to the browser, must be prefixed with VITE_
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Backend (api/*.js Vercel Serverless Functions) — server-side only, never
# expose to the browser. Set these as Environment Variables in the Vercel
# project (and copy this file to .env for local `vercel dev`).
GEMINI_API_KEY=your-gemini-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

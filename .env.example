# Frontend (Vite) — exposed to the browser, must be prefixed with VITE_
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Backend (api/*.js Vercel Serverless Functions) — server-side only, never
# expose to the browser. Set these as Environment Variables in the Vercel
# project (and copy this file to .env for local `vercel dev`).
GEMINI_API_KEY=your-gemini-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Service role key (Project Settings > API in Supabase) — only used by
# api/account.js to permanently delete a user's auth.users row. Keep this out
# of the browser bundle; it must never be prefixed with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
